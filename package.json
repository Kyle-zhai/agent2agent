{
  "name": "agent2agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:init": "TSX_TSCONFIG_PATH=tsconfig.test.json node --import tsx scripts/db-init.ts",
    "reset-password": "TSX_TSCONFIG_PATH=tsconfig.test.json node --import tsx scripts/reset-password.ts",
    "db:reset": "rm -f data/a2a.db data/a2a.db-shm data/a2a.db-wal && npm run db:init",
    "demo": "npm run db:init && node scripts/seed-demo.mjs",
    "test": "TSX_TSCONFIG_PATH=tsconfig.test.json node --import tsx --test 'tests/**/*.test.ts'"
  },
  "dependencies": {
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "better-sqlite3": "^11.5.0",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.4.49"
  }
}
