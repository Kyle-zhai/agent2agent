# Agent2Agent local config
# Copy to .env.local and fill in.

# Cookie session secret (32+ random bytes, base64)
SESSION_SECRET=change-me-to-random-bytes

# Public URL (used in install.md script)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Heartbeat polling interval hint (seconds), surfaced to install.md
A2A_HEARTBEAT_SECONDS=15
