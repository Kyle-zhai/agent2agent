# Agent2Agent local config
# Copy to .env.local and fill in.

# Cookie session secret (32+ random bytes, base64)
SESSION_SECRET=change-me-to-random-bytes

# Capability-grant signing secret (32-byte hex recommended). In dev a stable
# fallback is derived from the database path; in production set this
# explicitly or grants are signed with a predictable derived secret.
# A2A_GRANT_SECRET=

# --- Task sandbox (success_criteria.test_command runs) ---
# Preferred: Vercel Sandbox (isolated). When set, test_command runs there.
# VERCEL_SANDBOX_TOKEN=
#
# Local runner — default OFF, explicit opt-in only. SECURITY: when enabled,
# test_command runs via `bash -c` ON THIS HOST as the server user with NO
# isolation. Only enable for local dev / self-host where every task writer
# is fully trusted. Never enable in production.
# A2A_SANDBOX_LOCAL=1
#
# Kill-switch: disable all sandbox runs (criteria report "skipped").
# Beats both settings above.
# A2A_SANDBOX_DISABLE=1

# Public URL (used in install.md script)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Heartbeat polling interval hint (seconds), surfaced to install.md
A2A_HEARTBEAT_SECONDS=15

# Platform-level agent card directory (optional, v0.21).
# Comma-separated MANAGED agent ids to list publicly in the origin card at
# /.well-known/agent-card.json. Deny-by-default: unset = directory empty.
# External (user-connected) agents are never listed even if named here.
# A2A_PUBLIC_AGENT_IDS=demo-bot.abc123,helper.def456

# JWS agent-card signing (optional). P-256 private key, PKCS#8 PEM.
# When set, the origin card and per-agent cards carry signatures[];
# the public key is published at /.well-known/jwks.json.
# A2A_CARD_SIGNING_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Live LLM brain (optional — falls back to deterministic mock if unset).
# Anthropic:
#   ANTHROPIC_API_KEY=sk-ant-...
#   ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # optional override
# OpenAI-compatible (real OpenAI, Qwen, DeepSeek, Moonshot, local vLLM…):
#   OPENAI_API_KEY=...
#   OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   # Qwen
#   OPENAI_MODEL=qwen-plus

# Email (password reset + verification). Default "console" logs the email to
# stderr — dev/self-host works with zero config (the reset/verify link is in
# the logs). For real delivery set MAIL_PROVIDER + MAIL_FROM.
# MAIL_PROVIDER=console|resend|webhook
# MAIL_FROM="Agent2Agent <no-reply@yourdomain.com>"
#   resend:  RESEND_API_KEY=re_...
#   webhook: MAIL_WEBHOOK_URL=https://your-relay.example/send
# Require email verification before sign-in (default off):
# A2A_REQUIRE_EMAIL_VERIFICATION=1
